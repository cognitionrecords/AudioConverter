<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Audio Format Converter</title>
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/lamejs/1.2.0/lame.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { margin: 0; padding: 0; background-color: #1a202c; }
  </style>
</head>
<body>
  <div id="root"></div>
  
  <script type="text/babel">
    const { useState, useRef, useEffect } = React;
    
    // Lucide icons as inline SVG components
    const Upload = ({className, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
    );
    
    const Download = ({className, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    );
    
    const Play = ({className, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
    );
    
    const Pause = ({className, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
    );
    
    const Square = ({className, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
    );
    
    const ZoomIn = ({className, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    );
    
    const ZoomOut = ({className, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
    );
    
    const Star = ({className, fill, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill={fill || "none"} stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    );
    
    const X = ({className, ...props}) => (
      <svg className={className} {...props} width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    );

    const AudioConverter = () => {
      const [file, setFile] = useState(null);
      const [dragActive, setDragActive] = useState(false);
      const [audioContext, setAudioContext] = useState(null);
      const [audioBuffer, setAudioBuffer] = useState(null);
      const [waveformData, setWaveformData] = useState([]);
      const [duration, setDuration] = useState(0);
      const [converting, setConverting] = useState(false);
      const [convertedUrl, setConvertedUrl] = useState(null);
      const [isPlaying, setIsPlaying] = useState(false);
      const [currentTime, setCurrentTime] = useState(0);
      const [zoom, setZoom] = useState(1);
      const [outputName, setOutputName] = useState('converted');
      const [namePreset, setNamePreset] = useState('custom');
      const [customPrefix, setCustomPrefix] = useState('');
      const [favorites, setFavorites] = useState([
        { name: 'CD Quality WAV', format: 'wav', bitrate: '320', sampleRate: '44100', bitDepth: '16' },
        { name: 'Studio WAV 24bit', format: 'wav', bitrate: '320', sampleRate: '48000', bitDepth: '24' },
        { name: 'High Quality MP3', format: 'mp3', bitrate: '320', sampleRate: '44100', bitDepth: '16' }
      ]);
      
      const [settings, setSettings] = useState({
        outputFormat: 'wav',
        bitrate: '320',
        sampleRate: '44100',
        bitDepth: '16',
        channels: 'stereo'
      });

      const canvasRef = useRef(null);
      const fileInputRef = useRef(null);
      const sourceNodeRef = useRef(null);
      const startTimeRef = useRef(0);
      const animationRef = useRef(null);

      useEffect(() => {
        document.body.style.backgroundColor = '#1a202c';
        
        return () => {
          document.body.style.backgroundColor = '';
          if (animationRef.current) {
            cancelAnimationFrame(animationRef.current);
          }
          if (sourceNodeRef.current) {
            try {
              sourceNodeRef.current.stop();
            } catch (e) {}
          }
        };
      }, []);

      const formats = [
        { value: 'wav', label: 'WAV' },
        { value: 'mp3', label: 'MP3' }
      ];

      const bitrates = ['128', '192', '256', '320'];
      const sampleRates = ['44100', '48000', '96000'];
      const bitDepths = ['16', '24', '32'];
      const channelOptions = [
        { value: 'mono', label: 'Mono' },
        { value: 'stereo', label: 'Stereo' }
      ];
      
      const namePresets = [
        { value: 'custom', label: 'Custom' },
        { value: 'original', label: 'Original Name' },
        { value: 'prefix_date', label: 'Prefix + Date' },
        { value: 'prefix_format', label: 'Prefix + Format' }
      ];

      const formatTime = (seconds) => {
        const mins = Math.floor(seconds / 60);
        const secs = Math.floor(seconds % 60);
        return `${mins}:${secs.toString().padStart(2, '0')}`;
      };

      const formatFileSize = (bytes) => {
        return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
      };

      const generateOutputName = (preset, originalName) => {
        const baseName = originalName ? originalName.replace(/\.[^/.]+$/, '') : 'converted';
        const date = new Date().toISOString().split('T')[0];
        const prefix = customPrefix ? customPrefix + '_' : '';
        
        switch(preset) {
          case 'original':
            return prefix + baseName;
          case 'prefix_date':
            return prefix + baseName + '_' + date;
          case 'prefix_format':
            return prefix + baseName + '_' + settings.outputFormat;
          default:
            return prefix + outputName;
        }
      };

      const handleDrag = (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (e.type === 'dragenter' || e.type === 'dragover') {
          setDragActive(true);
        } else if (e.type === 'dragleave') {
          setDragActive(false);
        }
      };

      const handleDrop = (e) => {
        e.preventDefault();
        e.stopPropagation();
        setDragActive(false);
        
        if (e.dataTransfer.files && e.dataTransfer.files[0]) {
          handleFile(e.dataTransfer.files[0]);
        }
      };

      const handleFileInput = (e) => {
        if (e.target.files && e.target.files[0]) {
          handleFile(e.target.files[0]);
        }
      };

      const handleFile = async (uploadedFile) => {
        if (!uploadedFile.type.startsWith('audio/')) {
          alert('Please upload an audio file');
          return;
        }

        setFile(uploadedFile);
        setConvertedUrl(null);
        setIsPlaying(false);
        setCurrentTime(0);
        setOutputName(uploadedFile.name.replace(/\.[^/.]+$/, ''));

        try {
          const context = new (window.AudioContext || window.webkitAudioContext)();
          setAudioContext(context);

          const arrayBuffer = await uploadedFile.arrayBuffer();
          const buffer = await context.decodeAudioData(arrayBuffer);
          setAudioBuffer(buffer);
          
          const dur = buffer.duration;
          setDuration(dur);
          
          generateWaveform(buffer);
        } catch (error) {
          console.error('Error loading audio:', error);
          alert('Error loading audio file. Please try a different file.');
        }
      };

      const generateWaveform = (buffer) => {
        const rawData = buffer.getChannelData(0);
        const samples = 1000;
        const blockSize = Math.floor(rawData.length / samples);
        const filteredData = [];
        
        for (let i = 0; i < samples; i++) {
          let blockStart = blockSize * i;
          let sum = 0;
          for (let j = 0; j < blockSize; j++) {
            sum += Math.abs(rawData[blockStart + j]);
          }
          filteredData.push(sum / blockSize);
        }
        
        const multiplier = Math.pow(Math.max(...filteredData), -1);
        setWaveformData(filteredData.map(n => n * multiplier));
      };

      useEffect(() => {
        if (waveformData.length > 0 && canvasRef.current) {
          drawWaveform();
        }
      }, [waveformData, currentTime, zoom]);

      const drawWaveform = () => {
        const canvas = canvasRef.current;
        if (!canvas) return;
        
        const ctx = canvas.getContext('2d');
        const width = canvas.width;
        const height = canvas.height;
        
        ctx.clearRect(0, 0, width, height);
        
        ctx.fillStyle = '#1e293b';
        ctx.fillRect(0, 0, width, height);
        
        const dataToShow = waveformData.slice(0, Math.floor(waveformData.length * zoom));
        const barWidth = width / dataToShow.length;
        const progress = duration > 0 ? currentTime / duration : 0;
        
        dataToShow.forEach((value, i) => {
          const barHeight = value * height * 0.85;
          const x = i * barWidth;
          const y = (height - barHeight) / 2;
          
          if ((i / dataToShow.length) < (progress * zoom)) {
            ctx.fillStyle = '#3b82f6';
          } else {
            ctx.fillStyle = '#64748b';
          }
          
          ctx.fillRect(x, y, barWidth - 0.5, barHeight);
        });

        if (duration > 0) {
          const playheadX = (progress * zoom) * width;
          ctx.strokeStyle = '#ef4444';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.moveTo(playheadX, 0);
          ctx.lineTo(playheadX, height);
          ctx.stroke();
        }
      };

      const updatePlaybackTime = () => {
        if (isPlaying && audioContext) {
          const elapsed = audioContext.currentTime - startTimeRef.current;
          setCurrentTime(elapsed);
          
          if (elapsed >= duration) {
            handleStop();
          } else {
            animationRef.current = requestAnimationFrame(updatePlaybackTime);
          }
        }
      };

      const handlePlay = async () => {
        if (!audioContext || !audioBuffer) return;

        if (audioContext.state === 'suspended') {
          await audioContext.resume();
        }
        
        const source = audioContext.createBufferSource();
        source.buffer = audioBuffer;
        source.connect(audioContext.destination);
        
        source.start(0, currentTime);
        
        sourceNodeRef.current = source;
        startTimeRef.current = audioContext.currentTime - currentTime;
        setIsPlaying(true);
        
        source.onended = () => {
          setIsPlaying(false);
        };
        
        animationRef.current = requestAnimationFrame(updatePlaybackTime);
      };

      const handlePause = () => {
        if (sourceNodeRef.current) {
          try {
            sourceNodeRef.current.stop();
          } catch (e) {}
        }
        setIsPlaying(false);
        if (animationRef.current) {
          cancelAnimationFrame(animationRef.current);
        }
      };

      const handleStop = () => {
        handlePause();
        setCurrentTime(0);
      };

      const handleExport = async () => {
        if (!audioBuffer) return;
        
        setConverting(true);
        
        await new Promise(resolve => setTimeout(resolve, 1000));
        
        try {
          const targetChannels = settings.channels === 'mono' ? 1 : 2;
          
          const offlineContext = new OfflineAudioContext(
            targetChannels,
            audioBuffer.length,
            parseInt(settings.sampleRate)
          );
          
          const source = offlineContext.createBufferSource();
          source.buffer = audioBuffer;
          
          if (targetChannels === 1 && audioBuffer.numberOfChannels === 2) {
            const merger = offlineContext.createChannelMerger(1);
            const splitter = offlineContext.createChannelSplitter(2);
            const gainL = offlineContext.createGain();
            const gainR = offlineContext.createGain();
            gainL.gain.value = 0.5;
            gainR.gain.value = 0.5;
            
            source.connect(splitter);
            splitter.connect(gainL, 0);
            splitter.connect(gainR, 1);
            gainL.connect(merger, 0, 0);
            gainR.connect(merger, 0, 0);
            merger.connect(offlineContext.destination);
          } else {
            source.connect(offlineContext.destination);
          }
          
          source.start();
          
          const renderedBuffer = await offlineContext.startRendering();
          
          let blob;
          if (settings.outputFormat === 'mp3') {
            blob = await bufferToMP3(renderedBuffer);
          } else {
            blob = bufferToWave(renderedBuffer, parseInt(settings.bitDepth));
          }
          
          const url = URL.createObjectURL(blob);
          setConvertedUrl(url);
        } catch (error) {
          console.error('Export error:', error);
          alert('Error exporting audio. Please try again.');
        }
        
        setConverting(false);
      };

      const bufferToMP3 = async (buffer) => {
        try {
          const lamejs = window.lamejs;
          if (!lamejs) {
            alert('MP3 encoder not loaded. Using WAV instead.');
            return bufferToWave(buffer, 16);
          }
          
          const channels = buffer.numberOfChannels;
          const sampleRate = buffer.sampleRate;
          const mp3encoder = new lamejs.Mp3Encoder(channels, sampleRate, parseInt(settings.bitrate));
          const mp3Data = [];
          
          const leftChannel = buffer.getChannelData(0);
          const rightChannel = channels > 1 ? buffer.getChannelData(1) : leftChannel;
          
          const sampleBlockSize = 1152;
          
          for (let i = 0; i < leftChannel.length; i += sampleBlockSize) {
            const leftChunk = convertFloat32ToInt16(leftChannel.subarray(i, i + sampleBlockSize));
            const rightChunk = convertFloat32ToInt16(rightChannel.subarray(i, i + sampleBlockSize));
            
            const mp3buf = mp3encoder.encodeBuffer(leftChunk, rightChunk);
            if (mp3buf.length > 0) {
              mp3Data.push(mp3buf);
            }
          }
          
          const mp3buf = mp3encoder.flush();
          if (mp3buf.length > 0) {
            mp3Data.push(mp3buf);
          }
          
          return new Blob(mp3Data, { type: 'audio/mp3' });
        } catch (error) {
          console.error('MP3 encoding error:', error);
          alert('MP3 encoding failed. Using WAV instead.');
          return bufferToWave(buffer, 16);
        }
      };

      const convertFloat32ToInt16 = (buffer) => {
        const l = buffer.length;
        const buf = new Int16Array(l);
        for (let i = 0; i < l; i++) {
          const s = Math.max(-1, Math.min(1, buffer[i]));
          buf[i] = s < 0 ? s * 0x8000 : s * 0x7FFF;
        }
        return buf;
      };

      const bufferToWave = (buffer, bitDepth) => {
        const bytesPerSample = bitDepth / 8;
        const length = buffer.length * buffer.numberOfChannels * bytesPerSample + 44;
        const arrayBuffer = new ArrayBuffer(length);
        const view = new DataView(arrayBuffer);
        const channels = [];
        let offset = 0;
        let pos = 0;

        const setUint16 = (data) => {
          view.setUint16(pos, data, true);
          pos += 2;
        };

        const setUint32 = (data) => {
          view.setUint32(pos, data, true);
          pos += 4;
        };

        setUint32(0x46464952);
        setUint32(length - 8);
        setUint32(0x45564157);
        setUint32(0x20746d66);
        setUint32(16);
        setUint16(bitDepth === 32 ? 3 : 1);
        setUint16(buffer.numberOfChannels);
        setUint32(buffer.sampleRate);
        setUint32(buffer.sampleRate * bytesPerSample * buffer.numberOfChannels);
        setUint16(buffer.numberOfChannels * bytesPerSample);
        setUint16(bitDepth);
        setUint32(0x61746164);
        setUint32(length - pos - 4);

        for (let i = 0; i < buffer.numberOfChannels; i++) {
          channels.push(buffer.getChannelData(i));
        }

        while (pos < length) {
          for (let i = 0; i < buffer.numberOfChannels; i++) {
            let sample = Math.max(-1, Math.min(1, channels[i][offset]));
            
            if (bitDepth === 16) {
              sample = sample < 0 ? sample * 0x8000 : sample * 0x7FFF;
              view.setInt16(pos, sample, true);
              pos += 2;
            } else if (bitDepth === 24) {
              sample = sample < 0 ? sample * 0x800000 : sample * 0x7FFFFF;
              const int24 = Math.round(sample);
              view.setUint8(pos++, int24 & 0xFF);
              view.setUint8(pos++, (int24 >> 8) & 0xFF);
              view.setUint8(pos++, (int24 >> 16) & 0xFF);
            } else if (bitDepth === 32) {
              view.setFloat32(pos, sample, true);
              pos += 4;
            }
          }
          offset++;
        }

        return new Blob([arrayBuffer], { type: 'audio/wav' });
      };

      const loadFavorite = (fav) => {
        setSettings({
          outputFormat: fav.format,
          bitrate: fav.bitrate,
          sampleRate: fav.sampleRate,
          bitDepth: fav.bitDepth,
          channels: settings.channels
        });
      };

      const saveFavorite = () => {
        const name = prompt('Enter preset name:');
        if (name) {
          setFavorites([...favorites, {
            name,
            format: settings.outputFormat,
            bitrate: settings.bitrate,
            sampleRate: settings.sampleRate,
            bitDepth: settings.bitDepth
          }]);
        }
      };

      const deleteFavorite = (index) => {
        setFavorites(favorites.filter((_, i) => i !== index));
      };

      return (
        <div className="min-h-screen bg-[#1a202c] text-gray-200 p-6" style={{backgroundColor: '#1a202c'}}>
          <style>{`
            select {
              background-color: #000000 !important;
              color: #e5e7eb !important;
            }
            select option {
              background-color: #000000 !important;
              color: #e5e7eb !important;
            }
            input[type="text"] {
              background-color: #000000 !important;
              color: #e5e7eb !important;
            }
          `}</style>
          
          <div className="max-w-6xl mx-auto" style={{backgroundColor: '#1a202c'}}>
            <div className="mb-4">
              <h1 className="text-2xl font-bold text-[#38bdf8] mb-1">🎵 Audio Format Converter</h1>
              <p className="text-sm text-gray-400">Professional audio conversion tool</p>
            </div>

            <div
              className={`border-2 border-dashed rounded-lg p-8 mb-4 transition-all cursor-pointer ${
                dragActive ? 'border-[#38bdf8] bg-[#2d3748]' : 'border-[#4a5568] bg-[#2d3748]'
              }`}
              onDragEnter={handleDrag}
              onDragLeave={handleDrag}
              onDragOver={handleDrag}
              onDrop={handleDrop}
              onClick={() => fileInputRef.current?.click()}
            >
              <input
                ref={fileInputRef}
                type="file"
                accept="audio/*"
                onChange={handleFileInput}
                className="hidden"
              />
              
              <div className="text-center">
                <Upload className="w-10 h-10 mx-auto mb-2 text-gray-400" />
                <p className="text-sm mb-1 text-gray-200">
                  {file ? file.name : 'Drop audio file or click to browse'}
                </p>
                <p className="text-xs text-gray-400">
                  MP3, WAV, FLAC, AAC, OGG, AIFF
                </p>
              </div>
            </div>

            {file && (
              <>
                <div className="bg-[#2d3748] rounded-lg p-4 mb-4">
                  <h3 className="text-sm font-semibold text-gray-300 mb-3">Input File Info</h3>
                  <div className="grid grid-cols-2 gap-x-6 gap-y-2 text-xs">
                    <div className="flex justify-between">
                      <span className="text-gray-400">Filename:</span>
                      <span className="text-gray-200 font-mono">{file.name}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-gray-400">Size:</span>
                      <span className="text-gray-200 font-mono">{formatFileSize(file.size)}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-gray-400">Format:</span>
                      <span className="text-gray-200 font-mono">{file.type.split('/')[1]?.toUpperCase() || 'AUDIO'}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-gray-400">Duration:</span>
                      <span className="text-gray-200 font-mono">{formatTime(duration)}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-gray-400">Sample Rate:</span>
                      <span className="text-gray-200 font-mono">{audioBuffer ? `${(audioBuffer.sampleRate / 1000).toFixed(1)} kHz` : '-'}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-gray-400">Channels:</span>
                      <span className="text-gray-200 font-mono">{audioBuffer?.numberOfChannels === 2 ? 'Stereo (2)' : audioBuffer?.numberOfChannels === 1 ? 'Mono (1)' : '-'}</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-gray-400">Bit Depth:</span>
                      <span className="text-gray-200 font-mono">16-bit</span>
                    </div>
                    <div className="flex justify-between">
                      <span className="text-gray-400">Total Samples:</span>
                      <span className="text-gray-200 font-mono">{audioBuffer ? audioBuffer.length.toLocaleString() : '-'}</span>
                    </div>
                  </div>
                </div>

                <div className="bg-[#2d3748] rounded-lg p-4 mb-4">
                  <div className="flex items-center justify-between mb-3">
                    <h3 className="text-sm font-semibold text-gray-300">Waveform</h3>
                    <div className="flex items-center gap-2">
                      <button
                        onClick={() => setZoom(Math.max(0.5, zoom - 0.25))}
                        className="p-1.5 bg-[#1a202c] hover:bg-[#374151] rounded transition-colors"
                        title="Zoom Out"
                      >
                        <ZoomOut className="w-4 h-4" />
                      </button>
                      <button
                        onClick={() => setZoom(Math.min(3, zoom + 0.25))}
                        className="p-1.5 bg-[#1a202c] hover:bg-[#374151] rounded transition-colors"
                        title="Zoom In"
                      >
                        <ZoomIn className="w-4 h-4" />
                      </button>
                      <button
                        onClick={isPlaying ? handlePause : handlePlay}
                        className="px-3 py-1.5 bg-[#3b82f6] hover:bg-[#2563eb] rounded text-sm flex items-center gap-1.5 transition-colors"
                      >
                        {isPlaying ? <Pause className="w-3.5 h-3.5" /> : <Play className="w-3.5 h-3.5" />}
                        {isPlaying ? 'Pause' : 'Play'}
                      </button>
                      <button
                        onClick={handleStop}
                        className="px-3 py-1.5 bg-[#ef4444] hover:bg-[#dc2626] rounded text-sm flex items-center gap-1.5 transition-colors"
                      >
                        <Square className="w-3.5 h-3.5" />
                        Stop
                      </button>
                    </div>
                  </div>
                  
                  <canvas
                    ref={canvasRef}
                    width={1000}
                    height={100}
                    className="w-full rounded cursor-pointer"
                    onClick={(e) => {
                      const rect = canvasRef.current.getBoundingClientRect();
                      const x = e.clientX - rect.left;
                      const progress = x / rect.width;
                      const newTime = (progress / zoom) * duration;
                      setCurrentTime(newTime);
                      
                      if (isPlaying && sourceNodeRef.current) {
                        try {
                          sourceNodeRef.current.stop();
                        } catch (e) {}
                        setIsPlaying(false);
                      }
                    }}
                  />
                  
                  <div className="flex justify-between mt-2 text-xs text-gray-400">
                    <span>{formatTime(currentTime)}</span>
                    <span>Zoom: {zoom}x</span>
                    <span>{formatTime(duration)}</span>
                  </div>
                </div>

                <div className="bg-[#2d3748] rounded-lg p-4 mb-4">
                  <div className="flex items-center justify-between mb-3">
                    <div>
                      <h3 className="text-sm font-semibold text-gray-300">Output Settings</h3>
                      <p className="text-xs text-gray-400 mt-0.5">
                        Converting: <span className="text-cyan-400">{file.type.split('/')[1]?.toUpperCase() || 'AUDIO'}</span> → <span className="text-green-400">{settings.outputFormat.toUpperCase()}</span>
                      </p>
                    </div>
                    <button
                      onClick={saveFavorite}
                      className="px-3 py-1.5 bg-[#1a202c] hover:bg-[#374151] rounded text-xs flex items-center gap-1.5 transition-colors"
                    >
                      <Star className="w-3.5 h-3.5" />
                      Save Preset
                    </button>
                  </div>
                  
                  <div className="grid grid-cols-4 gap-3 mb-3">
                    <div>
                      <label className="block text-xs text-gray-400 mb-1.5">Format</label>
                      <select
                        value={settings.outputFormat}
                        onChange={(e) => setSettings({...settings, outputFormat: e.target.value})}
                        className="w-full bg-[#000000] border border-[#4a5568] rounded px-3 py-1.5 text-sm text-gray-200"
                      >
                        {formats.map(fmt => (
                          <option key={fmt.value} value={fmt.value}>{fmt.label}</option>
                        ))}
                      </select>
                    </div>

                    <div>
                      <label className="block text-xs text-gray-400 mb-1.5">Bitrate (kbps)</label>
                      <select
                        value={settings.bitrate}
                        onChange={(e) => setSettings({...settings, bitrate: e.target.value})}
                        className="w-full bg-[#000000] border border-[#4a5568] rounded px-3 py-1.5 text-sm text-gray-200"
                      >
                        {bitrates.map(br => (
                          <option key={br} value={br}>{br}</option>
                        ))}
                      </select>
                    </div>

                    <div>
                      <label className="block text-xs text-gray-400 mb-1.5">Sample Rate</label>
                      <select
                        value={settings.sampleRate}
                        onChange={(e) => setSettings({...settings, sampleRate: e.target.value})}
                        className="w-full bg-[#000000] border border-[#4a5568] rounded px-3 py-1.5 text-sm text-gray-200"
                      >
                        {sampleRates.map(sr => (
                          <option key={sr} value={sr}>{(parseInt(sr) / 1000).toFixed(1)} kHz</option>
                        ))}
                      </select>
                    </div>

                    <div>
                      <label className="block text-xs text-gray-400 mb-1.5">Bit Depth</label>
                      <select
                        value={settings.bitDepth}
                        onChange={(e) => setSettings({...settings, bitDepth: e.target.value})}
                        className="w-full bg-[#000000] border border-[#4a5568] rounded px-3 py-1.5 text-sm text-gray-200"
                        disabled={settings.outputFormat === 'mp3'}
                      >
                        {bitDepths.map(bd => (
                          <option key={bd} value={bd}>{bd}-bit</option>
                        ))}
                      </select>
                    </div>
                  </div>

                  <div className="grid grid-cols-3 gap-3 mb-3">
                    <div>
                      <label className="block text-xs text-gray-400 mb-1.5">Channels</label>
                      <select
                        value={settings.channels}
                        onChange={(e) => setSettings({...settings, channels: e.target.value})}
                        className="w-full bg-[#000000] border border-[#4a5568] rounded px-3 py-1.5 text-sm text-gray-200"
                      >
                        {channelOptions.map(ch => (
                          <option key={ch.value} value={ch.value}>{ch.label}</option>
                        ))}
                      </select>
                    </div>

                    <div>
                      <label className="block text-xs text-gray-400 mb-1.5">Custom Prefix</label>
                      <input
                        type="text"
                        value={customPrefix}
                        onChange={(e) => setCustomPrefix(e.target.value)}
                        className="w-full bg-[#000000] border border-[#4a5568] rounded px-3 py-1.5 text-sm text-gray-200"
                        placeholder="prefix"
                      />
                    </div>

                    <div>
                      <label className="block text-xs text-gray-400 mb-1.5">Filename Preset</label>
                      <select
                        value={namePreset}
                        onChange={(e) => {
                          setNamePreset(e.target.value);
                          if (e.target.value !== 'custom') {
                            setOutputName(generateOutputName(e.target.value, file.name));
                          }
                        }}
                        className="w-full bg-[#000000] border border-[#4a5568] rounded px-3 py-1.5 text-sm text-gray-200"
                      >
                        {namePresets.map(preset => (
                          <option key={preset.value} value={preset.value}>{preset.label}</option>
                        ))}
                      </select>
                    </div>
                  </div>

                  <div className="mb-3">
                    <label className="block text-xs text-gray-400 mb-1.5">Output Filename</label>
                    <input
                      type="text"
                      value={namePreset === 'custom' ? outputName : generateOutputName(namePreset, file.name)}
                      onChange={(e) => {
                        setOutputName(e.target.value);
                        setNamePreset('custom');
                      }}
                      className="w-full bg-[#000000] border border-[#4a5568] rounded px-3 py-1.5 text-sm text-gray-200"
                      placeholder="output"
                    />
                  </div>

                  {favorites.length > 0 && (
                    <div>
                      <label className="block text-xs text-gray-400 mb-1.5">Saved Presets</label>
                      <div className="flex flex-wrap gap-2">
                        {favorites.map((fav, idx) => (
                          <button
                            key={idx}
                            onClick={() => loadFavorite(fav)}
                            className="group relative px-3 py-1.5 bg-[#1a202c] hover:bg-[#374151] rounded text-xs text-gray-300 border border-[#4a5568] transition-colors flex items-center gap-2"
                          >
                            {fav.name}
                            <X
                              className="w-3 h-3 opacity-0 group-hover:opacity-100 text-red-400 hover:text-red-300"
                              onClick={(e) => {
                                e.stopPropagation();
                                deleteFavorite(idx);
                              }}
                            />
                          </button>
                        ))}
                      </div>
                    </div>
                  )}
                </div>

                <div className="flex gap-3">
                  <button
                    onClick={handleExport}
                    disabled={converting}
                    className="flex-1 bg-[#3b82f6] hover:bg-[#2563eb] disabled:bg-[#4a5568] disabled:cursor-not-allowed text-white font-semibold py-3 rounded transition-all flex items-center justify-center gap-2"
                  >
                    {converting ? (
                      <>
                        <div className="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin" />
                        Converting...
                      </>
                    ) : (
                      <>
                        Convert to {settings.outputFormat.toUpperCase()}
                      </>
                    )}
                  </button>

                  {convertedUrl && (
                    <a
                      href={convertedUrl}
                      download={`${generateOutputName(namePreset, file.name)}.${settings.outputFormat}`}
                      className="flex-1 bg-[#10b981] hover:bg-[#059669] text-white font-semibold py-3 rounded transition-all flex items-center justify-center gap-2"
                    >
                      <Download className="w-4 h-4" />
                      Download {settings.outputFormat.toUpperCase()}
                    </a>
                  )}
                </div>
              </>
            )}
          </div>
        </div>
      );
    };
    
    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<AudioConverter />);
  </script>
</body>
</html>
